{
  "manifest_version": 3,
  "name": "Linko Sync",
  "version": "1.0.0",
  "description": "Sincronizza tutti i tuoi segnalibri Chrome con Linko in un click.",

  "permissions": ["bookmarks", "storage"],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Linko Sync",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
