# ─────────────────────────────────────────────────────────────────────────────
# Linko — Environment Configuration
# Copia questo file in .env e compila i valori
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=linko
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=linkodb
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# JWT Auth
JWT_SECRET=genera_con_openssl_rand_hex_32
JWT_REFRESH_SECRET=genera_con_openssl_rand_hex_32_diverso
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Worker tuning
WORKER_REPLICAS=1
WORKER_CONCURRENCY=5
SCRAPING_DELAY_MS=1200       # ms tra una richiesta e l'altra (rate limiting)
SCRAPING_TIMEOUT_MS=10000    # timeout per lo scraping OpenGraph
HTTP_CHECK_TIMEOUT_MS=8000   # timeout per il check HTTP status
